#include<stdio.h>
#include<stdlib.h>
struct node
{
    int data;
    struct node *next;
};
int main()
{
    int n,i;
    struct node *head=NULL,*temp,*newnode;
    scanf("%d",&n);
    for(i=0;i<n;i++)
    {
        newnode=(struct node*)malloc(sizeof(struct node));
        scanf("%d",&newnode->data);
        
        if(head==NULL)
        {
            head=newnode;
            temp=newnode;
        }
        else
        {
            temp->next=newnode;
            temp=newnode;
        }
        
    }
    int pos;
    scanf("%d",&pos);
    for(i=0;i<pos;i++)
    {
        if(head!=NULL)
        {
        temp=head;
        head=head->next;
        free(temp);
        }
    }
    if(head==NULL)
    {
        printf("List is empty");
    }
    else
    {
    temp=head;
    while(temp!=NULL)
    {
        printf("%d ",temp->data);
        temp=temp->next;
    }
    }
    return 0;
} 
